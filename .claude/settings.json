{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Read(./.env.staging)",
      "Read(./.env.development)",
      "Read(./.env.test)",
      "Edit(./.env)",
      "Edit(./.env.local)",
      "Edit(./.env.production)",
      "Edit(./.env.staging)",
      "Edit(./.env.development)",
      "Edit(./.env.test)",
      "Write(./.env)",
      "Write(./.env.local)",
      "Write(./.env.production)",
      "Write(./.env.staging)",
      "Write(./.env.development)",
      "Write(./.env.test)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre/jira-ticket-check.sh",
            "shell": "bash",
            "timeout": 10,
            "if": "Bash(git commit*)",
            "statusMessage": "Checking commit message for Jira ticket"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre/secret-scan.sh",
            "shell": "bash",
            "timeout": 30,
            "if": "Bash(git commit*, git add*)",
            "statusMessage": "Scanning staged files for secrets"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre/lint-check.sh",
            "shell": "bash",
            "timeout": 60,
            "if": "Bash(git commit*)",
            "statusMessage": "Running lint and typecheck"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre/env-guard.sh",
            "shell": "bash",
            "timeout": 10,
            "statusMessage": "Verifying .env protection"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre/secret-scan.sh",
            "shell": "bash",
            "timeout": 30,
            "statusMessage": "Scanning for secrets"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post/jira-update.sh",
            "shell": "bash",
            "timeout": 30,
            "if": "Bash(git commit*)",
            "statusMessage": "Queueing Jira update"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/post/screenshot-capture.sh",
            "shell": "bash",
            "timeout": 120,
            "if": "Bash(npm run dev*, npm run build*, next dev*, next build*)",
            "statusMessage": "Capturing screenshots",
            "async": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/post/screenshot-compare.sh",
            "shell": "bash",
            "timeout": 60,
            "if": "Bash(npm run dev*, npm run build*, next dev*, next build*)",
            "statusMessage": "Comparing screenshots to reference",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post/notify-done.sh",
            "shell": "bash",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
