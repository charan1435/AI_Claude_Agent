# Test environment variables — copy to .env.test.local and fill in values.
# NEVER commit real credentials or .env.test.local to version control.

# -----------------------------------------------------------------------
# Unit and component tests (Jest)
# These mocked tests do not hit a real Supabase instance.
# Leave empty or use placeholder values.
# -----------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# -----------------------------------------------------------------------
# RLS isolation test (src/__tests__/rls/rls-isolation.test.ts)
# Requires a real Supabase instance (local emulator recommended).
# When absent, the RLS test suite skips cleanly.
# -----------------------------------------------------------------------
SUPABASE_TEST_URL=http://localhost:54321
SUPABASE_TEST_ANON_KEY=your-anon-key-here

# -----------------------------------------------------------------------
# E2E tests (Playwright — e2e/*.spec.ts)
# Requires a running local Supabase + Next.js dev server.
# When E2E_SUPABASE_URL is absent, all e2e tests skip cleanly.
# -----------------------------------------------------------------------
E2E_SUPABASE_URL=http://localhost:54321
E2E_TEST_USER_EMAIL=e2e_user@example.com
E2E_TEST_USER_PASSWORD=TestPassword123!
