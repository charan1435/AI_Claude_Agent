# ============================================================
# Personal Expense Tracker — environment variables
#
# Copy this file to .env.local and fill in your Supabase project values.
# NEVER commit .env.local or any .env.* files to version control.
#
# NOTE: The Supabase SERVICE_ROLE key is intentionally NOT required by
# this application. Row-Level Security (RLS) on the `expenses` table
# enforces all per-user authorization — no elevated server-side key is
# needed in the MVP. If you add webhook handlers in the future, scope
# them to a separate server function and inject the service-role key
# there only.
# ============================================================

# Your Supabase project URL (find it in Settings > API)
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase anon (public) key (find it in Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
